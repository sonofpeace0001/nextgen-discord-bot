# ═══════════════════════════════════════════════════════
# NEXTGEN Bot — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════

# Discord (required)
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_GUILD_ID=1410778472032370700

# AI Providers (at least one required)
GROQ_API_KEY=your_groq_key
GEMINI_API_KEY=your_gemini_key
OPENROUTER_API_KEY=your_openrouter_key

# Roles
ADMIN_ROLE_ID=your_admin_role_id
VERIFIED_ROLE_ID=your_verified_role_id
CONTRIBUTOR_ROLE=your_contributor_role_id
MUTED_ROLE=your_muted_role_id

# Channels — fill in the ones you have
CH_WELCOME=1450106084147859529
CH_LOG=1410803080374649005
CH_GENERAL=
CH_RULES=
CH_INTRODUCTION=
CH_VERIFY=
CH_ANNOUNCEMENTS=
CH_MOD_REPORT=1410803080374649005
CH_STAFF_CHAT=
CH_GMGN=
CH_X_TASKS=
CH_MEME=
CH_CONTENT=
CH_CONTRIBUTOR_CHAT=
CH_CONTRIBUTOR_RPT=
CH_HANGOUT=
CH_MINI_UPDATES=
CH_INVITES=
CH_SUPPORT=

# Bot identity
BOT_NAME=NEXTGEN
BOT_COLOR=5865F2
COMMUNITY_NAME=NEXTGEN

# X/Twitter
X_ACCOUNT=your_x_handle
TWITTER_BEARER_TOKEN=
OFFICIAL_INVITE=your_discord_invite_code

# Channels bot never posts in (comma-separated IDs)
BLOCKED_CHANNELS=

# Channels bot reads but doesn't chat in (comma-separated IDs)
SILENT_CHANNELS=
